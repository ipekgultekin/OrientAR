<resources>

    <!-- Base application theme -->
    <style name="Theme.OrientAR" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#8B0000</item>
        <item name="colorPrimaryVariant">#6D0000</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FFF9C4</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">#8B0000</item>
    </style>

    <!-- AR Navigation fullscreen theme (used by ArNavigationActivity) -->
    <style name="Theme.AppCompat.NoActionBar.AR" parent="Theme.AppCompat.NoActionBar" />

    <!-- Treasure Hunt dialog theme (moved from strings.xml) -->
    <style name="CustomDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>

</resources>