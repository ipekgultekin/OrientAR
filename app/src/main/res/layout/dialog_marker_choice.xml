<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Destination name with pin icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_campus_navigation"
            android:tint="@color/campus_go_red"
            android:contentDescription="Location" />

        <TextView
            android:id="@+id/markerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/campus_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Set as starting point button -->
    <LinearLayout
        android:id="@+id/btnSetStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_campus_input_field"
        android:padding="14dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/campus_dot_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Set as starting point"
            android:textColor="@color/campus_text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Set as destination button -->
    <LinearLayout
        android:id="@+id/btnSetDestination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_campus_input_field"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/campus_dot_red" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Set as destination"
            android:textColor="@color/campus_text_primary"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
