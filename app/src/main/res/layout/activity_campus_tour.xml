<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/metu_gray">

    <!-- Layer 1: Full-screen map (behind everything) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 2: Top card (overlaps map) -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_route_card"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="18dp">

        <!-- Row 1: Logo + Title + My Location chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- METU Logo circle -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="OrientAR logo" />

            <!-- Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAMPUS TOUR"
                    android:textColor="@color/campus_header_title"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <!-- My Location chip -->
            <LinearLayout
                android:id="@+id/chipMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_campus_location_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@color/campus_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="My location"
                    android:textColor="@color/campus_chip_green_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Route input card (From / Swap / To) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_campus_input_field"
            android:orientation="vertical"
            android:padding="3dp">

            <!-- FROM field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <!-- Green dot -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@color/campus_dot_green" />

                <!-- From input -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FROM"
                        android:textColor="@color/campus_label"
                        android:textSize="9sp"
                        android:letterSpacing="0.05" />

                    <AutoCompleteTextView
                        android:id="@+id/inputFrom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Search starting point..."
                        android:textColorHint="@color/campus_placeholder"
                        android:textColor="@color/campus_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:imeOptions="actionNext"
                        android:completionThreshold="1"
                        android:padding="0dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider with swap button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Horizontal divider line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/campus_divider" />

                <!-- Swap button (overlaps divider, aligned right) -->
                <ImageButton
                    android:id="@+id/btnSwap"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_campus_swap_button"
                    android:src="@drawable/ic_campus_swap"
                    android:scaleType="centerInside"
                    android:padding="5dp"
                    android:contentDescription="Swap start and destination"
                    android:elevation="1dp" />
            </FrameLayout>

            <!-- TO field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <!-- Red square -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@color/campus_dot_red" />

                <!-- To input -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TO"
                        android:textColor="@color/campus_label"
                        android:textSize="9sp"
                        android:letterSpacing="0.05" />

                    <AutoCompleteTextView
                        android:id="@+id/inputTo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Search destination..."
                        android:textColorHint="@color/campus_placeholder"
                        android:textColor="@color/campus_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:imeOptions="actionDone"
                        android:completionThreshold="1"
                        android:padding="0dp" />
                </LinearLayout>

                <!-- Search icon -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_campus_search"
                    android:contentDescription="Search"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Layer 3: Bottom bar (overlaps map bottom) -->
    <FrameLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="28dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Bar background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_campus_bar"
            android:elevation="0dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Toggle container -->
            <FrameLayout
                android:id="@+id/toggleContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <!-- Sliding indicator (positioned programmatically) -->
                <View
                    android:id="@+id/toggleIndicator"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_campus_toggle_selected"
                    android:elevation="0dp" />

                <!-- Tab buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 2D Nav tab -->
                    <TextView
                        android:id="@+id/btnModeMap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:drawableStart="@drawable/ic_campus_map"
                        android:drawablePadding="5dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="2D Nav"
                        android:textColor="@color/campus_toggle_border"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@android:color/transparent" />

                    <!-- AR Nav tab -->
                    <TextView
                        android:id="@+id/btnModeAR"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:drawableStart="@drawable/ic_campus_ar"
                        android:drawablePadding="5dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="AR Nav"
                        android:textColor="@color/campus_inactive_text"
                        android:textSize="12sp"
                        android:background="@android:color/transparent" />
                </LinearLayout>
            </FrameLayout>

            <!-- GO button (slightly overflows vertically) -->
            <ImageButton
                android:id="@+id/btnStartNavigation"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="-4dp"
                android:layout_marginBottom="-4dp"
                android:background="@drawable/bg_campus_go_circle"
                android:src="@drawable/ic_campus_navigation"
                android:scaleType="centerInside"
                android:padding="13dp"
                android:elevation="6dp"
                android:contentDescription="Start navigation" />
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>
