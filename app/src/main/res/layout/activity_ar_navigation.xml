<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- AR Scene View - Base Layer -->
    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/arView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ============================================================ -->
    <!-- NAVIGATION UI - Top Bar (Shown during navigation) -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Destination Icon -->
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="#E31837" />

        <!-- Destination Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDestinationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Destination"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRouteInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating..."
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Distance -->
        <TextView
            android:id="@+id/tvRemainingDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--m"
            android:textColor="#E31837"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- NAVIGATION UI - Bottom Card (Shown during navigation) -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutBottomCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Progress Bar Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/progressNavigation"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_red" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Next Checkpoint Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNextCheckpoint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@android:drawable/ic_menu_directions"
                android:drawablePadding="8dp"
                android:drawableTint="#E31837"
                android:text="Next: --"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvETA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ETA: --"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRecalibrate"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_outline"
                android:text="🔄 Recalibrate"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnEndNavigation"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_red"
                android:text="End Navigation"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- COMPASS HUD (Left side during navigation) -->
    <!-- ============================================================ -->
    <FrameLayout
        android:id="@+id/layoutCompassHud"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="200dp"
        android:background="@drawable/bg_compass"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivCompassArrow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_compass_arrow"
            app:tint="#E31837" />

        <TextView
            android:id="@+id/tvCompassBearing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="6dp"
            android:text="N"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- ============================================================ -->
    <!-- DEBUG TOGGLE BUTTON (Right side) -->
    <!-- ============================================================ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="200dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:id="@+id/layoutDebugButtons">

        <!-- Phase 3 Toggle Button -->
        <ImageButton
            android:id="@+id/btnPhase3Toggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_debug_toggle"
            android:contentDescription="Toggle Phase 3"
            android:src="@android:drawable/ic_menu_manage"
            android:scaleType="centerInside"
            android:padding="10dp"
            app:tint="#FFFFFF" />

        <!-- Debug Toggle Button -->
        <ImageButton
            android:id="@+id/btnDebugToggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_debug_toggle"
            android:contentDescription="Toggle Debug"
            android:src="@android:drawable/ic_menu_info_details"
            android:scaleType="centerInside"
            android:padding="10dp"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- DEBUG PANEL (Toggleable - Hidden by default) -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutDebugPanel"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="180dp"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Debug Panel Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔧 Debug Panel"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Close Debug Panel Button -->
            <ImageButton
                android:id="@+id/btnCloseDebugPanel"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_small"
                android:contentDescription="Close"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:scaleType="centerInside"
                android:padding="4dp"
                app:tint="#FF5252" />

            <!-- Quick Recalibrate Button -->
            <Button
                android:id="@+id/btnDebugRecalibrate"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/bg_button_small"
                android:paddingHorizontal="8dp"
                android:text="🔄 Recalib"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <!-- Quick Flip 180 Button -->
            <Button
                android:id="@+id/btnDebugFlip"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_button_small"
                android:paddingHorizontal="8dp"
                android:text="↩️ Flip"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <Button
                android:id="@+id/btnShareLogs"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_button_small"
                android:paddingHorizontal="8dp"
                android:text="📤 Logs"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF" />

        <!-- Scrollable Debug Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvDebugInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:text="Debug info loading..."
                android:textColor="#4CAF50"
                android:textSize="11sp" />
        </ScrollView>
    </LinearLayout>
    <!-- ============================================================ -->
    <!-- RECALCULATING BANNER (Center - shown during drift correction) -->
    <!-- ============================================================ -->
    <TextView
        android:id="@+id/tvRecalculating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_card"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:text="⚠️ Recalibrating..."
        android:textColor="#FF9800"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- ============================================================ -->
    <!-- CALIBRATION PANEL (Center - shown during calibration steps) -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutCalibration"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivStepIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_infinite"
            app:tint="#E31837" />

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Calibrating..."
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStepDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Please wait"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="20dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_red"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnForceStart"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_outline"
            android:paddingHorizontal="24dp"
            android:text="Skip"
            android:textAllCaps="false"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- ROUTE SELECTION PANEL (Fallback - rarely shown) -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutRouteSelection"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="🧭 Select Route"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Starting Point"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerStartNode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_button_outline"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Destination"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerEndNode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_button_outline"
            android:padding="8dp" />

        <Button
            android:id="@+id/btnConfirmRoute"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_red"
            android:text="Start Navigation"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- OLD DEBUG PANEL (Keep for backward compatibility, hidden) -->
    <!-- ============================================================ -->
    <ScrollView
        android:id="@+id/debugPanel"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="#90000000"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="Waiting..."
            android:textColor="#00FF00"
            android:textSize="12sp" />
    </ScrollView>

    <!-- ============================================================ -->
    <!-- ARRIVAL CELEBRATION OVERLAY -->
    <!-- ============================================================ -->
    <include
        android:id="@+id/layoutArrivalCelebration"
        layout="@layout/layout_arrival_celebration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>