<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_info_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvFormalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Announcement Title"
        android:textColor="#2B2B2B"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFormalMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Announcement message"
        android:textColor="#2B2B2B"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvFormalMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="By coordinator"
        android:textColor="#666666"
        android:textSize="12sp" />

</LinearLayout>
