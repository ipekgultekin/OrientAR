<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="true" />
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".MyApp"
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="OrientAR"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OrientAR"
        tools:targetApi="31">

        <meta-data
            android:name="com.google.ar.core"
            android:value="required"
            tools:replace="android:value" />

        <meta-data
            android:name="com.google.android.ar.API_KEY"
            android:value="AIzaSyAhXjK2Div5AL4AzKObIkjrUx5BCH4Exdc" />


        <activity
            android:name=".auth.WelcomeActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".auth.StudentLoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.LeaderLoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".home.MainActivity"
            android:exported="false"
            android:label="METU NCC Orientation" />

        <activity
            android:name=".treasure.ScoreboardActivity"
            android:exported="false"
            android:label="Scoreboard" />

        <activity
            android:name=".treasure.TreasureHuntGameActivity"
            android:exported="false"
            android:label="Treasure Hunt Game" />

        <activity
            android:name=".chatbot.ChatbotActivity"
            android:exported="false"
            android:label="Chatbot" />

        <activity
            android:name=".societies.SocietiesActivity"
            android:exported="false"
            android:label="Student Societies" />

        <activity
            android:name=".societies.SocietyDetailActivity"
            android:exported="false"
            android:label="Society Detail" />

    </application>

</manifest>